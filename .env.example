# ============================================================
# Sarkari Portal — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these in Render Dashboard → Your Service → Environment
# ============================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────
# Find in: Supabase Dashboard → Settings → API

SUPABASE_URL=https://bqfeywhfrhbgvolwulaj.supabase.co

# ⚠️  SECRET — paste only in Render Dashboard / Replit Secrets, never in code
# Find in: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key_here...

# ── Telegram Bot (OPTIONAL — bot disabled if not set) ────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
TELEGRAM_BOT_TOKEN=123456789:AAF...your_bot_token_here...

# 2. Your personal Telegram chat ID (numeric)
#    To find it: message @userinfobot on Telegram, it replies with your ID
TELEGRAM_ADMIN_CHAT_ID=123456789

# ── Scraper Tuning ───────────────────────────────────────────
SCRAPER_INTERVAL_MINUTES=5      # how often to poll for new posts
SCRAPER_LIMIT_PER_CATEGORY=0    # max new items per category per run (0 = unlimited)
REQUEST_DELAY=1.5               # seconds between page requests

# ============================================================
# HOW TO SET SECRETS IN RENDER
# ============================================================
# 1. Go to render.com → Your service → Environment
# 2. Click "Add Environment Variable"
# 3. For secrets (SUPABASE_SERVICE_KEY, TELEGRAM_BOT_TOKEN, TELEGRAM_ADMIN_CHAT_ID):
#    - Type the key name
#    - Paste the value
#    - Check "Secret" checkbox (hides value after saving)
# 4. Click "Save Changes" — Render will restart the service automatically
# ============================================================
